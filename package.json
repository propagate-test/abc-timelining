{
  "name": "timelining",
  "version": "1.0.1",
  "description": "status: in-progress, early-stage",
  "scripts": {
    "db:up": "docker-compose -f ./test/test-env/docker-compose.yml up -d",
    "db:down": "docker-compose -f ./test/test-env/docker-compose.yml down --remove-orphans",
    "db:reset": "docker-compose -f ./test/test-env/docker-compose.yml down -v && docker volume rm neo4j_data",
    "wait:neo4j": "node ./test/scripts/health-check.cjs",
    "test": "pnpm run db:up && pnpm run wait:neo4j && jest && pnpm run db:down",
    "set:webhook": "tsx scripts/setWebhook.ts",
    "get:webhook": "tsx scripts/getWebhook.ts",
    "triggerIngest": "tsx scripts/triggerIngest.ts",
    "trigger:resolve": "tsx scripts/triggerOrganisingResolve.ts",
    "trigger:resolve:list": "tsx scripts/triggerOrganisingResolve.ts --list",
    "trigger:resolve:routes": "tsx scripts/triggerOrganisingResolve.ts --list-routes",
    "db:backlog": "tsx scripts/db/pipeline-backlog.ts",
    "db:backlog:ingest": "tsx scripts/db/pipeline-backlog.ts --stage ingest",
    "db:backlog:vectorise": "tsx scripts/db/pipeline-backlog.ts --stage vectorise",
    "db:vector-index:backfill": "tsx scripts/db/vector-index-backfill.ts",
    "db:vector-index:check": "tsx scripts/db/vector-index-check.ts",
    "db:vector-index:create": "tsx scripts/db/vector-index-create.ts",
    "db:vector-index:recreate": "tsx scripts/db/vector-index-create.ts --recreate",
    "db:check:page-ingest": "tsx scripts/db/check-page-ingest.ts",
    "db:seed:docs-pages": "tsx scripts/db/seed-docs-pages.ts",
    "db:delete:older-decisions": "tsx scripts/db/delete-older-decisions.ts",
    "vectorise:pages": "tsx scripts/run-page-vectorise.ts",
    "dev": "next dev --turbopack",
    "build": "next build"
  },
  "dependencies": {
    "@langchain/textsplitters": "^1.0.1",
    "@upstash/redis": "^1.34.8",
    "axios": "^1.9.0",
    "dotenv": "^16.5.0",
    "inquirer": "^12.6.0",
    "neo4j-driver": "^4.4.11",
    "next": "15.3.8",
    "node-telegram-bot-api": "^0.63.0",
    "openai": "^6.39.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "supertest": "^7.1.0",
    "typescript": "^5.8.3",
    "winston": "^3.17.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@next/eslint-plugin-next": "^15.3.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.34",
    "@types/react": "19.1.2",
    "@types/supertest": "^6.0.3",
    "@types/yargs": "^17.0.33",
    "@vercel/node": "^2.15.10",
    "eslint": "^9.26.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "node-mocks-http": "^1.17.2",
    "ts-jest": "^29.3.2",
    "tsx": "^4.19.4",
    "typescript-eslint": "^8.32.0",
    "wait-on": "^8.0.3"
  }
}
